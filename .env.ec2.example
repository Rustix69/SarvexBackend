# Sarvex EC2 demo backend environment.
# Copy to .env on the EC2 instance and change the password/origins before running.

PROJECT_NAME=sarvaex
DEMO_MODE=true
TZ=UTC

POSTGRES_USER=sarvaex
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=sarvaex
POSTGRES_HOST=localhost
POSTGRES_PORT=15432

NATS_PORT=4222
NATS_MONITOR_PORT=8222
REDIS_PORT=16379

# Host ports. Keep these blocked from the public internet in the EC2 security group.
REFDATA_GRPC_PORT=50061
REFDATA_HTTP_PORT=18061
LEDGER_GRPC_PORT=50062
LEDGER_HTTP_PORT=18062
RISK_GRPC_PORT=50063
RISK_HTTP_PORT=18063
ME_CORE_GRPC_PORT=50064
ORDER_ROUTER_GRPC_PORT=50065
ORDER_ROUTER_HTTP_PORT=18065
POSITION_GRPC_PORT=50066
POSITION_HTTP_PORT=18066
ORACLE_GRPC_PORT=50067
ORACLE_HTTP_PORT=18067
SETTLEMENT_GRPC_PORT=50068
SETTLEMENT_HTTP_PORT=18068
AUDIT_GRPC_PORT=50069
AUDIT_HTTP_PORT=18069
ADMIN_GRPC_PORT=50070
ADMIN_HTTP_PORT=18070
GW_REST_HTTP_PORT=18080
GW_WS_HTTP_PORT=18081

# Comma-separated browser origins allowed by gw-rest CORS.
# Add your actual Vercel production domain after first deploy.
ALLOWED_ORIGINS=https://sarvaex.in,https://www.sarvaex.in,https://YOUR_PROJECT.vercel.app

